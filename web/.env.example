VITE_WEALL_APP_NAME=WeAll
VITE_WEALL_ENV_LABEL=dev
VITE_WEALL_ENABLE_DEV_TOOLS=1
VITE_WEALL_ENABLE_BOOTSTRAP_LIVE=1
VITE_WEALL_ENABLE_POH_TIER2_VIDEO_UPLOAD=0
VITE_WEALL_API_BASE=http://127.0.0.1:8000
VITE_WEALL_CLIENT_NAME=weall-web
VITE_WEALL_CLIENT_VERSION=0.1.0

# Local dev uses web/public/seeds.json so clean clones do not 404.
# Public observer builds must set VITE_WEALL_PUBLIC_TESTNET=true and pin the
# public chain/genesis/profile commitments below. Do not ship localhost as a public seed.
VITE_WEALL_SEED_MANIFEST_URL=/seeds.json
VITE_WEALL_SEEDS_URL=/seeds.json
VITE_WEALL_PUBLIC_TESTNET=false
VITE_WEALL_EXPECTED_CHAIN_ID=
VITE_WEALL_EXPECTED_GENESIS_HASH=
VITE_WEALL_EXPECTED_TX_INDEX_HASH=
VITE_WEALL_EXPECTED_PROTOCOL_PROFILE_HASH=

VITE_WEALL_MEDIA_REPLICATION_FACTOR=2
VITE_WEALL_MEDIA_DURABLE_OPERATOR_COUNT=2

# Self-hosted live verification room base URL. The provider is transport only; chain state grants verification.
VITE_WEALL_LIVE_ROOM_BASE_URL=https://video.weall.local
