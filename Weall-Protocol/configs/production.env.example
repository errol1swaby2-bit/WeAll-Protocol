# WeAll production runtime example
# Copy to your managed environment or secret-injection layer.
# Do not commit real secret values.

WEALL_MODE=prod
WEALL_CHAIN_ID=weall-main
WEALL_CORS_ORIGINS=https://weallprotocol.xyz,https://app.weallprotocol.xyz

# Identity / validator
WEALL_NODE_ID=@validator-1
WEALL_VALIDATOR_ACCOUNT=@validator-1
WEALL_NODE_PRIVKEY_FILE=/run/secrets/weall_node_privkey
WEALL_NODE_PUBKEY_FILE=/run/secrets/weall_node_pubkey
WEALL_VALIDATOR_ACCOUNT_FILE=/run/secrets/weall_validator_account

# Networking / validator posture
WEALL_NET_ENABLED=1
WEALL_BFT_ENABLED=1
WEALL_VALIDATOR_SIGNING_ENABLED=1

# PoH / secrets
WEALL_POH_EMAIL_SECRET_FILE=/run/secrets/weall_poh_email_secret

# Gunicorn
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
