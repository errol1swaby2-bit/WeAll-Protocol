# SQLite runtime files (safety net if someone points WEALL_DB_PATH outside data/)
*.db
*.db-wal
*.db-shm
*.sqlite
*.aux.sqlite

# BFT / helper local runtime artifacts
.pytest-b*
*.bft_journal.jsonl
*.aux_helper_lanes/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# WeAll local/runtime artifacts
.weall/
src/weall_protocol.egg-info/
*.egg-info/

# Compose backups
docker-compose.yml.bak*
*.bak
*.bak2

# Local configs that may contain secrets
configs/local/

