def test_bft_adversarial_matrix_cli_runs_all_scenarios(tmp_path: Path) -> None:
    env = {"PYTHONPATH": str(_repo_root() / "src")}
    proc = subprocess.run(
        [
            sys.executable,
            str(_repo_root() / "scripts" / "bft_adversarial_matrix.py"),
            "--work-dir",
            str(tmp_path),
            "--chain-id-prefix",
            "bft-batch18-matrix",
        ],
        cwd=str(_repo_root()),
        capture_output=True,
        text=True,
        env=env,
        check=False,
    )
    assert proc.returncode == 0, proc.stderr
    payload = json.loads(proc.stdout)
    assert payload["ok"] is True
    assert int(payload["scenario_count"]) == 6
    scenarios = payload["scenarios"]
    assert scenarios["partition_restart_rejoin"]["converged"] is True
    assert scenarios["stall_recovery"]["stalled_delivery_events"] >= 3
    assert scenarios["epoch_shift_rejoin"]["stale_qc_replay_rejections"] >= 1
    assert scenarios["clock_skew_warning"]["forced_clock_skew_warnings"] >= 1

    epoch_restart = scenarios["epoch_restart_stale_qc"]
    assert epoch_restart["converged"] is True
    assert int(epoch_restart["epoch_bump_events"]) == 3
    assert int(epoch_restart["stale_qc_replay_rejections"]) == int(
        epoch_restart["stale_qc_replay_attempts"]
    )
    assert int(epoch_restart["restart_events"]) >= 4
    assert int(epoch_restart["delayed_child_first_events"]) == 0

    long_soak = scenarios["five_validator_long_soak"]
    assert long_soak["converged"] is True
    assert len(long_soak["validator_ids"]) == 5
    assert int(long_soak["leader_height"]) == 18
    assert int(long_soak["restart_events"]) >= 3
    assert int(long_soak["epoch_bump_events"]) == 1
    assert int(long_soak["stale_qc_replay_rejections"]) == int(
        long_soak["stale_qc_replay_attempts"]
    )
    assert int(long_soak["delayed_child_first_events"]) == 0
